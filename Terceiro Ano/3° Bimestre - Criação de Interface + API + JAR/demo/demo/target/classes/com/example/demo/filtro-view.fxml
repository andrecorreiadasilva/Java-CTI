<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" maxHeight="204.0" maxWidth="213.0" minHeight="169.0" minWidth="213.0" prefHeight="169.0" prefWidth="213.0" spacing="20.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo.FiltroController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <Label text="Pesquisa de CEP">
      <font>
         <Font size="24.0" />
      </font>
   </Label>

    <Label fx:id="welcomeText" />
   <TextField fx:id="txtCep" promptText="Digite um CEP (Sem hífen)" />
    <Button fx:id="btnExibir" onAction="#onExibirButtonClick" prefHeight="26.0" prefWidth="99.0" text="Pesquisar CEP" />
</VBox>
